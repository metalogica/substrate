#!/usr/bin/env bash
# substrate — CLI entry point for substrate tooling. A real binary: symlink it
# onto your PATH with scripts/substrate-link.sh, then run `substrate <verb>` from
# anywhere. Self-locating — it resolves its own path through symlinks to find the
# repo, so there is no SUBSTRATE_ROOT to set.
#
#   substrate tasks [--tbd <slug>] [--fixture <path>] [--once]
#       live bead TUI for the project in your CURRENT directory
#
# Subcommands read tbd + .substrate from your current directory, so run from
# inside whatever project you want to see.
set -euo pipefail

# Resolve BASH_SOURCE through symlinks (macOS bash 3.2 safe) → repo root.
src="${BASH_SOURCE[0]}"
while [ -h "$src" ]; do
  dir="$(cd -P "$(dirname "$src")" && pwd)"
  src="$(readlink "$src")"
  [ "${src#/}" = "$src" ] && src="$dir/$src"   # relative link → re-anchor
done
here="$(cd -P "$(dirname "$src")" && pwd)"      # .../substrate/scripts
root="$(dirname "$here")"                        # .../substrate

sub="${1:-}"
[ "$#" -gt 0 ] && shift || true

case "$sub" in
  tasks)
    exec "$root/scripts/bead-tui.sh" "$@"
    ;;
  ui)
    exec "$root/scripts/substrate-ui.sh" "$@"
    ;;
  serve)
    exec npx -y tsx "$root/daemon/src/serve.ts"  --repo "$PWD" "$@"
    ;;
  status)
    exec npx -y tsx "$root/daemon/src/status.ts" --repo "$PWD" "$@"
    ;;
  tidy)
    exec npx -y tsx "$root/daemon/src/tidy.ts"   --repo "$PWD" "$@"
    ;;
  triage)
    exec npx -y tsx "$root/daemon/src/triage.ts" --repo "$PWD" "$@"
    ;;
  ""|-h|--help|help)
    cat <<'EOF'
substrate — substrate tooling CLI

usage:
  substrate tasks [--tbd <slug>] [--fixture <path>] [--once]
      live bead TUI for the project in your current directory
  substrate ui
      one-window tmux workspace for the project in your current directory
      (board / specs / agent windows on substrate's own tmux server;
       M-1..M-3 jump, M-n new agent window, prefix-d detach)
  substrate serve
      local-first pull daemon: poll the tbd board, claim groomed beads, build
      them as headless sessions in sibling worktrees, open PRs (serve-v1)
  substrate status
      aerial pipeline view of the serve daemon (board → building → in-review)
  substrate tidy
      manual reap: reconcile stale worktrees / claims / merged leftovers
  substrate triage <bead-id>
      claim + route + dispatch ONE bead now, bypassing the poll loop
EOF
    ;;
  *)
    echo "substrate: unknown command '$sub' (try: substrate tasks, ui, serve, status, tidy, triage)" >&2
    exit 2
    ;;
esac
